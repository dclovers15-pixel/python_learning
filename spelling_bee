words = {"hair": 4, "pair": 4, "chair": 5}


def main():
    print("welcome to spelling bee", "your letters are A I P C R H G", sep=", ")

    while len(words) > 0:
        print(f"{len(words)} words left")
        guess = input("guess a word: ").lower()
        if guess in words:
            print(f"you won! {words[guess]} points")
            words.pop(guess)
        else:
            print("incorrect")
